\section{\texorpdfstring{Introduction\hyperref[introduction]{}}{Introduction}}\label{introduction}

This framework provides support for various common elements for C++
papers. This document is intended to test various features implemented
in
\href{https://github.com/mpark/wg21}{\VERB|\NormalTok{mpark}\OperatorTok{/}\NormalTok{wg21}|}.

\section{\texorpdfstring{Title\hyperref[title]{}}{Title}}\label{title}

The title is specified by YAML metadata block.

\begin{Shaded}
\begin{Highlighting}[]
\PreprocessorTok{{-}{-}{-}}
\FunctionTok{title}\KeywordTok{:}\AttributeTok{ Example Title}
\FunctionTok{subtitle}\KeywordTok{:}\AttributeTok{ Example Subtitle}
\FunctionTok{document}\KeywordTok{:}\AttributeTok{ DxxxxRn}
\FunctionTok{date}\KeywordTok{:}\AttributeTok{ 2019{-}06{-}13}
\FunctionTok{audience}\KeywordTok{:}
\AttributeTok{  }\KeywordTok{{-}}\AttributeTok{ Library Evolution}
\AttributeTok{  }\KeywordTok{{-}}\AttributeTok{ Library}
\FunctionTok{author}\KeywordTok{:}
\AttributeTok{  }\KeywordTok{{-}}\AttributeTok{ }\FunctionTok{name}\KeywordTok{:}\AttributeTok{ Author One}
\AttributeTok{    }\FunctionTok{email}\KeywordTok{:}\AttributeTok{ \textless{}one@author.com\textgreater{}}
\AttributeTok{  }\KeywordTok{{-}}\AttributeTok{ }\FunctionTok{name}\KeywordTok{:}\AttributeTok{ Author Two}
\AttributeTok{    }\FunctionTok{email}\KeywordTok{:}\AttributeTok{ \textless{}two@author.com\textgreater{}}
\FunctionTok{toc}\KeywordTok{:}\AttributeTok{ }\CharTok{false}\CommentTok{    \# default: \textasciigrave{}true\textasciigrave{}}
\FunctionTok{toc{-}depth}\KeywordTok{:}\AttributeTok{ }\DecValTok{4}\CommentTok{  \# default: \textasciigrave{}3\textasciigrave{}}
\PreprocessorTok{{-}{-}{-}}
\end{Highlighting}
\end{Shaded}

\begin{quote}
\VERB|\NormalTok{date}\OperatorTok{:}\NormalTok{ today}| will generate
today's date in
\VERB|\NormalTok{YYYY}\OperatorTok{{-}}\NormalTok{MM}\OperatorTok{{-}}\NormalTok{DD}|
(ISO 8601) format.
\end{quote}

\section{\texorpdfstring{Markdown\hyperref[markdown]{}}{Markdown}}\label{markdown}

\href{https://pandoc.org/MANUAL.html\#pandocs-markdown}{Pandoc Markdown}
is the Markdown flavor used for this framework.

\subsection{\texorpdfstring{Inline
Formatting\hyperref[inline-formatting]{}}{Inline Formatting}}\label{inline-formatting}

Inline formatting such as \textbf{bold}, \emph{italics}, and
\VERB|\NormalTok{verbatim}| work as you would expect. There are also
useful extensions such as \st{strikeout}, su\textsubscript{b}script,
su\textsuperscript{per}script, and highlighted code:
\VERB|\KeywordTok{constexpr}|.

Various compositions in compact list:

\begin{itemize}
\tightlist
\item
  \st{{\mbox{\VERB|\NormalTok{A}\OperatorTok{\textless{}}\NormalTok{B}\OperatorTok{\textless{}}\NormalTok{T}\OperatorTok{\textgreater{}\textgreater{}}|}}}
\item
  \VERB|\NormalTok{compare\_3way}|
\item
  {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{compare\_3way}|}}}
\item
  \VERB|\NormalTok{3WAY}|\VERB|\OperatorTok{\textless{}}\NormalTok{R}\OperatorTok{\textgreater{}}|
\item
  \VERB|\KeywordTok{operator}\OperatorTok{@}|
\item
  \VERB|\KeywordTok{operator}\OperatorTok{+}|
\item
  \VERB|\NormalTok{x }\OperatorTok{@}\NormalTok{ y}|
\item
  \st{{\mbox{\VERB|\NormalTok{x }\OperatorTok{\&}\NormalTok{ y}|}}}
\item
  \textbf{foo \VERB|\KeywordTok{constexpr}| bar}
\item
  \emph{foo \VERB|\KeywordTok{constexpr}| bar}
\item
  \st{foo {\mbox{\VERB|\KeywordTok{constexpr}|}} bar}
\item
  {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{hello world}|}}}
\item
  \VERB|\NormalTok{{{\color[HTML]{006e28}\uline{hello\textless{}T\textgreater{}}}}}|
\item
  \st{\emph{{\mbox{\VERB|\NormalTok{hello world}|}}}}
\item
  \st{{\mbox{\VERB|\NormalTok{hello world}|}}}
\item
  \VERB|\KeywordTok{namespace}\NormalTok{ \emph{unspecified} }\OperatorTok{\{} \KeywordTok{struct}\NormalTok{ sender\_base }\OperatorTok{\{\}}\NormalTok{; }\OperatorTok{\}}|
\item
  \VERB|\KeywordTok{namespace}\NormalTok{ \emph{unspecified} }\OperatorTok{\{} \KeywordTok{struct}\NormalTok{ sender\_base }\OperatorTok{\{\}}\NormalTok{; }\OperatorTok{\}}|
\item
  \VERB|\KeywordTok{constexpr}\NormalTok{\emph{\textsubscript{opt}}}|
\item
  {{\setlength{\fboxsep}{1pt}\colorbox{yellow}{highlighted}}}
\item
  \VERB|\DataTypeTok{void}\NormalTok{ {{\setlength{\fboxsep}{1pt}\colorbox{yellow}{foo}}}}\OperatorTok{()}\NormalTok{;}|
\item
  {{\setlength{\fboxsep}{1pt}\colorbox{yellow}{{\mbox{\VERB|\DataTypeTok{void}\NormalTok{ foo}\OperatorTok{()}\NormalTok{;}|}}}}}
\item
  \(\frac{a+b}{2}\)
\end{itemize}

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

Loose list:

\begin{itemize}
\item
  \VERB|\NormalTok{x\emph{\textsubscript{i}} }\OperatorTok{\textless{}=\textgreater{}}\NormalTok{ y\emph{\textsubscript{i}}}|
\item
  {{\color[HTML]{bf0303}\sout{foo \VERB|\NormalTok{hello world}| bar}}}
\end{itemize}

