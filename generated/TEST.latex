\NormalTok{  {{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{\emph{as-receiver}(\emph{as-receiver}\&\& other) = default;}|}}}}
  \DataTypeTok{void}\NormalTok{ set\_value}\OperatorTok{()}\NormalTok{ {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{noexcept(is\_nothrow\_invocable\_v\textless{}F\&\textgreater{})}|}}} }\OperatorTok{\{}
\NormalTok{    invoke}\OperatorTok{(}\NormalTok{f\_}\OperatorTok{)}\NormalTok{;}
  \OperatorTok{\}}
\NormalTok{  {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{[[noreturn]]}|}}} }\DataTypeTok{void}\NormalTok{ set\_error}\OperatorTok{(}\NormalTok{std}\OperatorTok{::}\NormalTok{exception\_ptr}\OperatorTok{)}\NormalTok{ {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{noexcept}|}}} }\OperatorTok{\{}
\NormalTok{    terminate}\OperatorTok{()}\NormalTok{;}
