\NormalTok{  x\emph{\textsubscript{i}} }\OperatorTok{\textless{}=\textgreater{}}\NormalTok{ y\emph{\textsubscript{i}};}
\OperatorTok{\}}\NormalTok{;}

\ControlFlowTok{if} \OperatorTok{(}\NormalTok{x}\OperatorTok{)} \OperatorTok{\{}
  \ControlFlowTok{return} \StringTok{""}\BuiltInTok{sv}\NormalTok{;}
  \ControlFlowTok{return} \DecValTok{5}\BuiltInTok{ms}\NormalTok{;}
\OperatorTok{\}}

\NormalTok{std}\OperatorTok{::}\NormalTok{printf}\OperatorTok{(}\StringTok{"}\SpecialCharTok{\%d}\StringTok{"}\NormalTok{, x}\OperatorTok{)}\NormalTok{;}

\NormalTok{std}\OperatorTok{::}\NormalTok{variant}\OperatorTok{\textless{}}\NormalTok{I1, I2}\OperatorTok{\textgreater{}}\NormalTok{ input }\OperatorTok{=} \CharTok{\textquotesingle{}h\textquotesingle{}}\NormalTok{;}
\NormalTok{std}\OperatorTok{::}\NormalTok{variant}\OperatorTok{\textless{}}\NormalTok{I1, I2}\OperatorTok{\textgreater{}}\NormalTok{ input }\OperatorTok{=} \StringTok{"h"}\NormalTok{;}
\NormalTok{std}\OperatorTok{::}\NormalTok{variant}\OperatorTok{\textless{}}\NormalTok{I1, I2}\OperatorTok{\textgreater{}}\NormalTok{ input }\OperatorTok{=} \StringTok{"hello"}\NormalTok{;}

\CommentTok{// mapping from a \textasciigrave{}variant\textasciigrave{} of inputs to a \textasciigrave{}variant\textasciigrave{} of results:}
\KeywordTok{auto}\NormalTok{ output }\OperatorTok{=}\NormalTok{ std}\OperatorTok{::}\NormalTok{visit}\OperatorTok{\textless{}}\NormalTok{std}\OperatorTok{::}\NormalTok{variant}\OperatorTok{\textless{}}\NormalTok{O}\OperatorTok{\textless{}}\NormalTok{I1}\OperatorTok{\textgreater{}}\NormalTok{, O}\OperatorTok{\textless{}}\NormalTok{I2}\OperatorTok{\textgreater{}\textgreater{}\textgreater{}(}\NormalTok{process}\OperatorTok{\{\}}\NormalTok{, input}\OperatorTok{)}\NormalTok{;}

\CommentTok{// coercing different results to a common type:}
\KeywordTok{auto}\NormalTok{ result }\OperatorTok{=}\NormalTok{ std}\OperatorTok{::}\NormalTok{visit}\OperatorTok{\textless{}}\NormalTok{std}\OperatorTok{::}\NormalTok{common\_type\_t}\OperatorTok{\textless{}}\NormalTok{O}\OperatorTok{\textless{}}\NormalTok{I1}\OperatorTok{\textgreater{}}\NormalTok{, O}\OperatorTok{\textless{}}\NormalTok{I2}\OperatorTok{\textgreater{}\textgreater{}\textgreater{}(}\NormalTok{process}\OperatorTok{\{\}}\NormalTok{, input}\OperatorTok{)}\NormalTok{;}

\CommentTok{// visiting a \textasciigrave{}variant\textasciigrave{} for the side{-}effects, discarding results:}
\NormalTok{std}\OperatorTok{::}\NormalTok{visit}\OperatorTok{\textless{}}\DataTypeTok{void}\OperatorTok{\textgreater{}(}\NormalTok{process}\OperatorTok{\{\}}\NormalTok{, input}\OperatorTok{)}\NormalTok{;}

\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}
