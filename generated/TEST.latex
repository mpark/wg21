\KeywordTok{enum} \DataTypeTok{Result}\OperatorTok{\textless{}}\NormalTok{T}\OperatorTok{,}\NormalTok{ E}\OperatorTok{\textgreater{}} \OperatorTok{\{}
  \ConstantTok{Ok}\NormalTok{(T)}\OperatorTok{,}
  \ConstantTok{Err}\NormalTok{(E)}\OperatorTok{,}
\OperatorTok{\}}

\ControlFlowTok{match}\NormalTok{ parse(some\_input) }\OperatorTok{\{}
