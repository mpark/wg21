\NormalTok{  hello {{\color[HTML]{bf0303}\sout{constexpr~}}}detail::foo::template \emph{foo};}

\NormalTok{  [[using CC: opt(1), debug]] x;}

\NormalTok{  template \textless{}typename I\textgreater{}}
\NormalTok{  [[nodiscard]] auto operator()(I i) {-}\textgreater{} O\textless{}I\textgreater{} \{ /* ... */ \};}
\NormalTok{\};}

\NormalTok{{{\color[HTML]{006e28}\uline{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}}}}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}

