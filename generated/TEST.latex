\NormalTok{  {{\color[HTML]{bf0303}\sout{{\mbox{\VERB|\NormalTok{explicit \emph{as-receiver}(invocable\_type\&\& f)}|}}}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{{\mbox{\VERB|\NormalTok{\emph{as-receiver}(\emph{as-receiver}\&\& other) = default;}|}}}}}}
  \DataTypeTok{void}\NormalTok{ set\_value}\OperatorTok{()}\NormalTok{ {{\color[HTML]{006e28}\uline{{\mbox{\VERB|\NormalTok{noexcept(is\_nothrow\_invocable\_v\textless{}F\&\textgreater{})}|}}}}} }\OperatorTok{\{}
\NormalTok{    invoke}\OperatorTok{(}\NormalTok{f\_}\OperatorTok{)}\NormalTok{;}
  \OperatorTok{\}}
\NormalTok{  {{\color[HTML]{006e28}\uline{{\mbox{\VERB|\NormalTok{[[noreturn]]}|}}}}} }\DataTypeTok{void}\NormalTok{ set\_error}\OperatorTok{(}\NormalTok{std}\OperatorTok{::}\NormalTok{exception\_ptr}\OperatorTok{)}\NormalTok{ {{\color[HTML]{006e28}\uline{{\mbox{\VERB|\NormalTok{noexcept}|}}}}} }\OperatorTok{\{}
\NormalTok{    terminate}\OperatorTok{()}\NormalTok{;}
  \OperatorTok{\}}
  \DataTypeTok{void}\NormalTok{ set\_done}\OperatorTok{()} \KeywordTok{noexcept} \OperatorTok{\{\}}
\OperatorTok{\}}\NormalTok{;}

\DataTypeTok{void}\NormalTok{ f}\OperatorTok{(}\NormalTok{{{\color[HTML]{006e28}\uline{{\mbox{\VERB|\NormalTok{int *const *\emph{p\textsubscript{i}}}|}}}}}}\OperatorTok{)}\NormalTok{;}
\end{Highlighting}
\end{Shaded}

\hypertarget{diff-syntax-highlighting}{%
\subsubsection{\texorpdfstring{\texttt{diff} Syntax
Highlighting\protect\hyperlink{diff-syntax-highlighting}{}}{diff Syntax Highlighting}}\label{diff-syntax-highlighting}}

{

\renewcommand{\NormalTok}[1]{\textcolor[HTML]{898887}{#1}}

\renewcommand{\VariableTok}[1]{\textcolor[HTML]{006e28}{#1}}

\renewcommand{\StringTok}[1]{\textcolor[HTML]{bf0303}{#1}}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{some things just don\textquotesingle{}t change.}

\NormalTok{// 20.3.4 tuple{-}like access to pair:}
\StringTok{{-} constexpr typename tuple\_element\textless{}I, std::pair\textless{}T1, T2\textgreater{} \textgreater{}::type\&}
\VariableTok{+ constexpr tuple\_element\_t\textless{}I, pair\textless{}T1, T2\textgreater{} \textgreater{}\&}
\StringTok{{-}   get(std::pair\textless{}T1, T2\textgreater{}\&) noexcept;}
\VariableTok{+   get(pair\textless{}T1, T2\textgreater{}\&) noexcept;}

\NormalTok{\emph{unspecified} detail::foo::template foo;}
\VariableTok{+ \emph{unspecified} detail::foo::template foo;}
\StringTok{{-} \emph{unspecified} detail::foo::template foo;}
\end{Highlighting}
\end{Shaded}

}

\hypertarget{rust-syntax-highlighting}{%
\subsubsection{\texorpdfstring{\texttt{rust} Syntax
Highlighting\protect\hyperlink{rust-syntax-highlighting}{}}{rust Syntax Highlighting}}\label{rust-syntax-highlighting}}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{enum} \DataTypeTok{Result}\OperatorTok{\textless{}}\NormalTok{T}\OperatorTok{,}\NormalTok{ E}\OperatorTok{\textgreater{}} \OperatorTok{\{}
  \ConstantTok{Ok}\NormalTok{(T)}\OperatorTok{,}
  \ConstantTok{Err}\NormalTok{(E)}\OperatorTok{,}
\OperatorTok{\}}

\ControlFlowTok{match}\NormalTok{ parse(some\_input) }\OperatorTok{\{}
  \ConstantTok{Ok}\NormalTok{(v) }\OperatorTok{=\textgreater{}} \CommentTok{// use \textasciigrave{}v\textasciigrave{}}
  \ConstantTok{Err}\NormalTok{(err) }\OperatorTok{=\textgreater{}} \CommentTok{// use \textasciigrave{}err\textasciigrave{}}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}

\hypertarget{auto-header-links}{%
\subsection{\texorpdfstring{Automatic Header
Links\protect\hyperlink{auto-header-links}{}}{Automatic Header Links}}\label{auto-header-links}}

Automatic header links are written as
\VERB|\NormalTok{[](\#auto{-}header{-}links)}|, and renders as
\protect\hyperlink{auto-header-links}{Automatic Header Links}.

