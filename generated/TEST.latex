\hypertarget{proposed-wording}{%
\section{\texorpdfstring{Proposed
Wording\protect\hyperlink{proposed-wording}{}}{Proposed Wording}}\label{proposed-wording}}

\hypertarget{paragraph-numbers}{%
\subsection{\texorpdfstring{Paragraph
Numbers\protect\hyperlink{paragraph-numbers}{}}{Paragraph Numbers}}\label{paragraph-numbers}}

\pnum{2} An expression is \emph{potentially evaluated} unless it is an
unevaluated operand (7.2) or a subexpression thereof. The set of
\emph{potential results} of an expression
\VERB|\NormalTok{e}|
is defined as follows:

\begin{itemize}
\item
  \pnum{(2.1)} If
  \VERB|\NormalTok{e}|
  is an \emph{id-expression} (7.5.4), the set contains only
  \VERB|\NormalTok{e}|
  .
\item
  \pnum{(2.2)} If
  \VERB|\NormalTok{e}|
  is a subscripting operation (7.6.1.1) with an array operand, the set
  contains the potential results of that operand.
\end{itemize}

\hypertarget{wording-changes}{%
\subsection{\texorpdfstring{Wording
Changes\protect\hyperlink{wording-changes}{}}{Wording Changes}}\label{wording-changes}}

Large changes are
\VERB|\OperatorTok{:::}\NormalTok{ add}|
for additions,
\VERB|\OperatorTok{:::}\NormalTok{ rm}|
for removals.

\begin{quote}
Modify section {28.5.5
\href{https://wg21.link/format.functions}{{[}format.functions{]}}}:

{\color[HTML]{006e28}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{template\textless{}class... Args\textgreater{}}
\NormalTok{  string format(const locale\& loc, string\_view fmt, const Args\&... args);}
\end{Highlighting}
\end{Shaded}

\emph{Returns:}
\VERB|\NormalTok{vformat(loc, fmt, make\_format\_args(args...))}|
.}
\end{quote}

Small, inline changes are done with
\VERB|\OperatorTok{[}\KeywordTok{new}\NormalTok{ text}\OperatorTok{]\{.}\NormalTok{add}\OperatorTok{\}}|
or
\VERB|\OperatorTok{[}\NormalTok{old text}\OperatorTok{]\{.}\NormalTok{rm}\OperatorTok{\}}|
.

\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.1481}}
  >{\raggedright\arraybackslash}p{(\columnwidth - 2\tabcolsep) * \real{0.8519}}@{}}
\toprule()
\begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Specifier}
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Replacement}
\end{minipage} \\
\midrule()
\endhead

\VERB|\OperatorTok{\%}\NormalTok{a}|
& The locale's abbreviated weekday name. If the value does not contain a
valid weekday, {{\color[HTML]{bf0303}\sout{{\mbox{
\VERB|\NormalTok{setstate(ios::failbit)}|
}} is called}}} {{\color[HTML]{006e28}\uline{{\mbox{
\VERB|\NormalTok{format\_error}|
}} is thrown}}}. \\

\VERB|\OperatorTok{\%}\NormalTok{A}|
& The locale's full weekday name. If the value does not contain a valid
weekday, {{\color[HTML]{bf0303}\sout{{\mbox{
\VERB|\NormalTok{setstate(ios::failbit)}|
}} is called}}} {{\color[HTML]{006e28}\uline{{\mbox{
\VERB|\NormalTok{format\_error}|
}} is thrown}}}. \\
\bottomrule()
\end{longtable}

