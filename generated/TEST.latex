  \OperatorTok{[[}\KeywordTok{using}\AttributeTok{ CC}\OperatorTok{:}\AttributeTok{ opt}\OperatorTok{(}\DecValTok{1}\OperatorTok{)}\NormalTok{,}\AttributeTok{ debug}\OperatorTok{]]}\NormalTok{ x;}

