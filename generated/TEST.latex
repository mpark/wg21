\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{template\textless{}class, class\textgreater{} struct \emph{as-receiver}; \emph{// exposition only}}|}}}}

\NormalTok{{{\color[HTML]{006e28}\uline{template\textless{}class, class\textgreater{} struct \emph{as-invocable}; \emph{// exposition only}}}}}
