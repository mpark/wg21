\subsection{\texorpdfstring{No Syntax
Highlighting\hyperref[no-syntax-highlighting]{}}{No Syntax Highlighting}}\label{no-syntax-highlighting}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{\#include \textless{}iostream\textgreater{}}
\NormalTok{\#include "foo.h"}

\NormalTok{\_\_FILE\_\_;}

\NormalTok{int x = 42\textquotesingle{}234\textquotesingle{}234;}
\NormalTok{const int x = 42ul;}
\NormalTok{const int x = 0B01011;}

\NormalTok{bool b = true;}

\NormalTok{struct process \{}
\NormalTok{  hello {{\color[HTML]{bf0303}\sout{constexpr~}}}detail::foo::template \emph{foo};}

\NormalTok{  [[using CC: opt(1), debug]] x;}

\NormalTok{  template \textless{}typename I\textgreater{}}
\NormalTok{  [[nodiscard]] auto operator()(I i) {-}\textgreater{} O\textless{}I\textgreater{} \{ /* ... */ \};}
\NormalTok{\};}

\NormalTok{{{\color[HTML]{006e28}\uline{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}}}}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}

\NormalTok{\(\frac{a+b}{2}\)  // math}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{\emph{bar}}|}}}  // italicized code}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{\emph{baz}}|}}}  // italicized code}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{$bar$}|}}}  // raw \emph{bar}}
\NormalTok{{{\setlength{\fboxsep}{1pt}\colorbox{yellow}{\$}}}text{{\setlength{\fboxsep}{1pt}\colorbox{yellow}{\$}}}  highlighted $}
\end{Highlighting}
\end{Shaded}

\subsection{\texorpdfstring{C++ Syntax
Highlighting\hyperref[c-syntax-highlighting]{}}{C++ Syntax Highlighting}}\label{c-syntax-highlighting}

\begin{Shaded}
\begin{Highlighting}[]
\PreprocessorTok{\#include }\ImportTok{\textless{}iostream\textgreater{}}
\PreprocessorTok{\#include }\ImportTok{"foo.h"}

\OtherTok{\_\_FILE\_\_}\OperatorTok{;}

\DataTypeTok{int}\NormalTok{ x }\OperatorTok{=} \DecValTok{42\textquotesingle{}234\textquotesingle{}234}\OperatorTok{;}
\KeywordTok{const} \DataTypeTok{int}\NormalTok{ x }\OperatorTok{=} \DecValTok{42}\BuiltInTok{ul}\OperatorTok{;}
\KeywordTok{const} \DataTypeTok{int}\NormalTok{ x }\OperatorTok{=} \BaseNTok{0B01011}\OperatorTok{;}

\DataTypeTok{bool}\NormalTok{ b }\OperatorTok{=} \KeywordTok{true}\OperatorTok{;}

\KeywordTok{struct}\NormalTok{ process }\OperatorTok{\{}
\NormalTok{  hello {{\color[HTML]{006e28}\uline{constexpr~}}}detail}\OperatorTok{::}\NormalTok{foo}\OperatorTok{::}\KeywordTok{template}\NormalTok{ foo}\OperatorTok{;}

  \OperatorTok{[[}\KeywordTok{using}\AttributeTok{ CC}\OperatorTok{:}\AttributeTok{ opt}\OperatorTok{(}\DecValTok{1}\OperatorTok{),}\AttributeTok{ debug}\OperatorTok{]]}\NormalTok{ x}\OperatorTok{;}

  \KeywordTok{template} \OperatorTok{\textless{}}\KeywordTok{typename}\NormalTok{ I}\OperatorTok{\textgreater{}}
  \OperatorTok{[[}\AttributeTok{nodiscard}\OperatorTok{]]} \KeywordTok{auto} \KeywordTok{operator}\OperatorTok{()(}\NormalTok{I i}\OperatorTok{)} \OperatorTok{{-}\textgreater{}}\NormalTok{ O}\OperatorTok{\textless{}}\NormalTok{I}\OperatorTok{\textgreater{}} \OperatorTok{\{} \CommentTok{/* ... */} \OperatorTok{\};}

\NormalTok{  x\emph{\textsubscript{i}} }\OperatorTok{\textless{}=\textgreater{}}\NormalTok{ y\emph{\textsubscript{i}}}\OperatorTok{;}
\OperatorTok{\};}

\KeywordTok{template} \OperatorTok{\textless{}}\NormalTok{{{{\color[HTML]{bf0303}\sout{invocable}}}{{\color[HTML]{006e28}\uline{class}}}} F{{\color[HTML]{006e28}\uline{, class}}}}\OperatorTok{\textgreater{}}
\KeywordTok{struct}\NormalTok{ \emph{as-receiver} }\OperatorTok{\{}
\NormalTok{{{\color[HTML]{bf0303}\sout{private:}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{using invocable\_type = std::remove\_cvref\_t\textless{}F\textgreater;}}}}
\NormalTok{  {{{\color[HTML]{bf0303}\sout{invocable\_type}}}{{\color[HTML]{006e28}\uline{F}}}} f\_}\OperatorTok{;}
\NormalTok{{{\color[HTML]{bf0303}\sout{public:}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{explicit \emph{as-receiver}(invocable\_type\&\& f)}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{\emph{as-receiver}(\emph{as-receiver}\&\& other) = default;}}}}
  \DataTypeTok{void}\NormalTok{ set\_value}\OperatorTok{()}\NormalTok{ {{\color[HTML]{006e28}\uline{noexcept(is\_nothrow\_invocable\_v\textless{}F\&\textgreater)}}} }\OperatorTok{\{}
\NormalTok{    invoke}\OperatorTok{(}\NormalTok{f\_}\OperatorTok{);}
  \OperatorTok{\}}
\OperatorTok{\};}

\DataTypeTok{void}\NormalTok{ f}\OperatorTok{(}\NormalTok{{{\color[HTML]{006e28}\uline{int *const *\emph{p\textsubscript{i}}}}}}\OperatorTok{);}
