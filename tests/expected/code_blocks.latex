\subsection{\texorpdfstring{\texttt{diff} Syntax
Highlighting\hyperref[diff-syntax-highlighting]{}}{diff Syntax Highlighting}}\label{diff-syntax-highlighting}

{

\renewcommand{\NormalTok}[1]{\textcolor[HTML]{898887}{#1}}

\renewcommand{\VariableTok}[1]{\textcolor[HTML]{006e28}{#1}}

\renewcommand{\StringTok}[1]{\textcolor[HTML]{bf0303}{#1}}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{some things just don\textquotesingle{}t change.}

\NormalTok{// 20.3.4 tuple{-}like access to pair:}
\StringTok{{-} constexpr typename tuple\_element\textless{}I, std::pair\textless{}T1, T2\textgreater{} \textgreater{}::type\&}
\VariableTok{+ constexpr tuple\_element\_t\textless{}I, pair\textless{}T1, T2\textgreater{} \textgreater{}\&}
\StringTok{{-}   get(std::pair\textless{}T1, T2\textgreater{}\&) noexcept;}
\VariableTok{+   get(pair\textless{}T1, T2\textgreater{}\&) noexcept;}

\NormalTok{\emph{unspecified} detail::foo::template foo;}
\VariableTok{+ \emph{unspecified} detail::foo::template foo;}
\StringTok{{-} \emph{unspecified} detail::foo::template foo;}
\end{Highlighting}
\end{Shaded}

}

\subsection{\texorpdfstring{\texttt{rust} Syntax
Highlighting\hyperref[rust-syntax-highlighting]{}}{rust Syntax Highlighting}}\label{rust-syntax-highlighting}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{enum} \DataTypeTok{Result}\OperatorTok{\textless{}}\NormalTok{T}\OperatorTok{,}\NormalTok{ E}\OperatorTok{\textgreater{}} \OperatorTok{\{}
  \ConstantTok{Ok}\NormalTok{(T)}\OperatorTok{,}
  \ConstantTok{Err}\NormalTok{(E)}\OperatorTok{,}
\OperatorTok{\}}

\ControlFlowTok{match}\NormalTok{ parse(some\_input) }\OperatorTok{\{}
  \ConstantTok{Ok}\NormalTok{(v) }\OperatorTok{=\textgreater{}} \CommentTok{// use \textasciigrave{}v\textasciigrave{}}
  \ConstantTok{Err}\NormalTok{(err) }\OperatorTok{=\textgreater{}} \CommentTok{// use \textasciigrave{}err\textasciigrave{}}
\OperatorTok{\}}
\end{Highlighting}
