\VERB|\ControlFlowTok{else}| \emph{statement}\\
\strut ~~~~\VERB|\ControlFlowTok{switch} \OperatorTok{(}|
\emph{init-statement\textsubscript{opt}} \emph{condition}
\VERB|\OperatorTok{)}| \emph{statement}\\
\strut ~~~~{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{inspect}|
\VERB|\NormalTok{constexpr}|\textsubscript{\emph{opt}}
\VERB|\NormalTok{(}| \emph{init-statement\textsubscript{opt}}
