C++\hyperref[embedded-markdown-in-c]{}}{Embedded Markdown in C++}}\label{embedded-markdown-in-c}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{namespace \emph{unspecified} \{ struct sender\_base \{\}; \}}|}}}}
\NormalTok{{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{using \emph{unspecified}::sender\_base;}|}}}}

\KeywordTok{template} \OperatorTok{\textless{}}\NormalTok{{{{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{invocable}|}}}{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{class}|}}}} F{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{, class}|}}}}\OperatorTok{\textgreater{}}
\KeywordTok{struct}\NormalTok{ \emph{as-receiver} }\OperatorTok{\{}
\NormalTok{{{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{private:}|}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{using invocable\_type = std::remove\_cvref\_t\textless{}F\textgreater{};}|}}}}
\NormalTok{  {{{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{invocable\_type}|}}}{{\color[HTML]{006e28}\uline{\VERB|\NormalTok{F}|}}}} f\_}\OperatorTok{;}
\NormalTok{{{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{public:}|}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{explicit \emph{as-receiver}(invocable\_type\&\& f)}|}}}}
\NormalTok{  {{\color[HTML]{bf0303}\sout{\VERB|\NormalTok{\emph{as-receiver}(\emph{as-receiver}\&\& other) = default;}|}}}}
  \DataTypeTok{void}\NormalTok{ set\_value}\OperatorTok{()}\NormalTok{ {{\color[HTML]{006e28}\uline{\VERB|\NormalTok{noexcept(is\_nothrow\_invocable\_v\textless{}F\&\textgreater{})}|}}} }\OperatorTok{\{}
\NormalTok{    invoke}\OperatorTok{(}\NormalTok{f\_}\OperatorTok{);}
  \OperatorTok{\}}
\OperatorTok{\};}
\end{Highlighting}
