\section{\texorpdfstring{Stable
Names\hyperref[stable-names]{}}{Stable Names}}\label{stable-names}

Stable names are written as
\VERB|\OperatorTok{[}\NormalTok{basic}\OperatorTok{.}\NormalTok{life}\OperatorTok{]\{.}\NormalTok{sref}\OperatorTok{\}}|,
and render as {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life}{{[}basic.life{]}}}.

\begin{itemize}
\tightlist
\item
  Add the \VERB|\OperatorTok{{-}}| or
  \VERB|\OperatorTok{.}\NormalTok{unnumbered}| class to omit the section
  number.
\item
  Add the \VERB|\OperatorTok{.}\NormalTok{title}| class to add the
  section title.
\end{itemize}

Examples:

{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.5811}}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.4189}}@{}}
\toprule\noalign{}
\begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Markdown Source}
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Rendered Output}
\end{minipage} \\
\midrule\noalign{}
\endhead
\bottomrule\noalign{}
\endlastfoot
\VERB|\NormalTok{[basic.life]}| &
\href{https://eel.is/c++draft/basic.life}{{[}basic.life{]}} \\
\VERB|\NormalTok{[basic.life]/1}| &
\href{https://eel.is/c++draft/basic.life\#1}{{[}basic.life{]}/1} \\
\VERB|\NormalTok{[basic.life]/2.1}| &
\href{https://eel.is/c++draft/basic.life\#2.1}{{[}basic.life{]}/2.1} \\
\VERB|\NormalTok{[basic.life]\{.sref\}}| & {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life}{{[}basic.life{]}}} \\
\VERB|\NormalTok{[basic.life]\{.sref\}/1}| & {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life\#1}{{[}basic.life{]}/1}} \\
\VERB|\NormalTok{[basic.life]\{.sref .title\}}| & {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life}{{[}basic.life{]}}} \\
\VERB|\NormalTok{[basic.life]\{.sref .title\}/1}| & {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life\#1}{{[}basic.life{]}/1}} \\
\end{longtable}
}

Also supported:

{\def\LTcaptype{none} % do not increment counter
\begin{longtable}[]{@{}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.5811}}
  >{\raggedright\arraybackslash}p{(\linewidth - 2\tabcolsep) * \real{0.4189}}@{}}
\toprule\noalign{}
\begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Markdown Source}
\end{minipage} & \begin{minipage}[b]{\linewidth}\raggedright
\centering\arraybackslash\textbf{Rendered Output}
\end{minipage} \\
\midrule\noalign{}
\endhead
\bottomrule\noalign{}
\endlastfoot
\VERB|\NormalTok{[basic.life\#1]\{.sref\}}| & {6.8.4 Lifetime
\href{https://eel.is/c++draft/basic.life\#1}{{[}basic.life{]}/1}} \\
\VERB|\NormalTok{[basic.life]\{{-} .sref .title\}}| & {Lifetime
\href{https://eel.is/c++draft/basic.life}{{[}basic.life{]}}} \\
\end{longtable}
}

